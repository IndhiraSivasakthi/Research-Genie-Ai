{
  "manifest_version": 3,
  "name": "AI Research Assistant",
  "version": "1.0",
  "description": "Summarize text, generate bullet points and suggestions using AI",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}